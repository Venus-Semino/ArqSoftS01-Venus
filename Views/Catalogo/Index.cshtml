@model List<Catalogo.Models.Item>

@{
    ViewData["Title"] = "Catálogo";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Mi Catálogo</h1>
        <a asp-action="Agregar" class="btn btn-outline-primary">+ Agregar Videojuego</a>
    </div>

    <div class="genre-filter mb-4">
        <a asp-action="Index" class="badge rounded-pill bg-secondary text-decoration-none">Todos</a>
        @foreach (var gen in ViewBag.Generos as List<string>)
        {
            <span class="text-muted mx-1">|</span>
            <a asp-action="Index" asp-route-genero="@gen" class="badge rounded-pill bg-dark text-decoration-none border border-secondary">@gen</a>
        }
    </div>

    <hr class="border-secondary" />

    <div class="movie-grid">
        @foreach (var item in Model)
        {
            <div class="movie-card" onclick="location.href='@Url.Action("Detalle", new { id = item.Id })'">
                
                <div class="poster-container">
                    <img src="https://via.placeholder.com/300x450/1e1e2e/cdd6f4?text=@item.Titulo"
                         alt="Portada de @item.Titulo" />
                </div>
                
                <div class="movie-info">
                    <h3 class="movie-title">@item.Titulo</h3>
                    <p class="movie-meta">@item.Genero • @item.Ano</p>
                </div>
            </div>
        }
    </div>
</div>